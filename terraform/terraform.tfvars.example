resource_group_name = "rg-tickbook-demo"
registry_name       = "tickbookregistry.azurecr.io"
location            = "East US"

image_path = "nmdra/tickbook"
image_tag  = "latest"

services = {
  "event-service" = {
    port = 3001
    db   = "eventdb"
  }
  "user-service" = {
    port = 3002
    db   = "userdb"
  }
  "booking-service" = {
    port = 3003
    db   = "bookingdb"
  }
  "payment-service" = {
    port = 3004
    db   = "paymentdb"
  }
  "notification-service" = {
    port = 3005
    db   = ""
  }
}

postgres_password  = "REPLACE_WITH_SECURE_PASSWORD_MIN_32_CHARS"
postgres_user      = "postgres"
postgres_sslmode   = "disable"

jwt_secret         = "REPLACE_WITH_CRYPTOGRAPHICALLY_RANDOM_SECRET"
jwt_refresh_secret = "REPLACE_WITH_CRYPTOGRAPHICALLY_RANDOM_REFRESH_SECRET"

google_client_id       = "your-google-client-id"
google_client_secret   = "your-google-client-secret"
google_redirect_uri    = "http://localhost:3002/api/users/auth/google/callback"
frontend_success_url   = "http://localhost:3002/google-auth-success.html"
frontend_dashboard_url = "http://localhost:3000/dashboard"

stripe_secret_key     = "sk_test_YOUR_STRIPE_SECRET_KEY"
stripe_webhook_secret = "whsec_YOUR_WEBHOOK_SECRET"
stripe_currency       = "usd"
stripe_success_url    = "http://localhost:3004/api/payments/stripe/success"
stripe_cancel_url     = "http://localhost:3004/api/payments/stripe/cancel"

sendgrid_api_key     = ""
sendgrid_from_email  = "no-reply@tickbook.local"
twilio_account_sid   = ""
twilio_auth_token    = ""
twilio_sms_from      = ""
twilio_whatsapp_from = "whatsapp:+14155238886"

nginx_host = "localhost"
nginx_port = 80

vercel_api_token    = "secret"
vercel_project_name = "project-name"
vercel_branch       = "main"

allowed_origins = [
  "https://*.vercel.app",
]
