resource_group_name = "rg-tickbook-demo"
registry_name       = "tickbookregistry.azurecr.io"
location            = "East US"

image_path = "nmdra/tickbook"
image_tag  = "latest"

services = {
  "event-service" = {
    port = 3001
    db   = "eventdb"
  }
  "user-service" = {
    port = 3002
    db   = "userdb"
  }
  "booking-service" = {
    port = 3003
    db   = "bookingdb"
  }
  "payment-service" = {
    port = 3004
    db   = "paymentdb"
  }
}

postgres_password  = "your-secure-password-here"
postgres_user      = "postgres"
postgres_sslmode   = "disable"

jwt_secret         = "your-jwt-secret-min-32-chars"
jwt_refresh_secret = "your-jwt-refresh-secret-min-32-chars"

google_client_id       = "your-google-client-id"
google_client_secret   = "your-google-client-secret"
google_redirect_uri    = "http://localhost:3002/api/users/auth/google/callback"
frontend_success_url   = "http://localhost:3002/google-auth-success.html"
frontend_dashboard_url = "http://localhost:3000/dashboard"

stripe_secret_key     = ""
stripe_webhook_secret = ""
stripe_currency       = "usd"
stripe_success_url    = "http://localhost:3004/api/payments/stripe/success"
stripe_cancel_url     = "http://localhost:3004/api/payments/stripe/cancel"

nginx_host = "localhost"
nginx_port = 80

custom_domain = "example.com"
