resource_group_name = "rg-tickbook-demo"
registry_name       = "tickbookregistry.azurecr.io"
location            = "East US"

image_path = "nmdra/tickbook"
image_tag  = "latest"

services = {
  "event-service" = {
    port = 3001
    db   = "eventdb"
  }
  "user-service" = {
    port = 3002
    db   = "userdb"
  }
  "booking-service" = {
    port = 3003
    db   = "bookingdb"
  }
  "payment-service" = {
    port = 3004
    db   = "paymentdb"
  }
}

postgres_password  = "change-me"
jwt_secret         = "change-me"
jwt_refresh_secret = "change-me"

custom_domain = "example.com"
